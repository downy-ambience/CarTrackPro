# 선택사항 - Slack 알림
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Google Sheets 연동 (서비스 계정 방식)
# 1. Google Cloud Console에서 서비스 계정 생성 후 JSON 키 다운로드
# 2. JSON 파일을 프로젝트 폴더에 저장 (예: ./credentials.json)
# 3. 아래 경로를 설정하면 서버 시작 시 자동 인증됩니다
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./credentials.json

# 스프레드시트 ID (앱에서 자동 생성 시 자동으로 채워집니다)
GOOGLE_SPREADSHEET_ID=
